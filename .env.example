# Mistral API Configuration
MISTRAL_API_KEY=your_mistral_api_key_here

# Canva Connect API Configuration (OAuth Authorization Code + PKCE)
CANVA_CLIENT_ID=your_canva_client_id_here
CANVA_CLIENT_SECRET=your_canva_client_secret_here
CANVA_REDIRECT_URI=http://127.0.0.1:8501/
CANVA_SCOPES=brandtemplate:content:read asset:write design:content:read design:content:write brandtemplate:meta:read asset:read brandtemplate:content:write
CANVA_ACCESS_TOKEN=your_canva_access_token_here
CANVA_REFRESH_TOKEN=your_canva_refresh_token_here

# Optional: Canva Brand Template ID (placeholder)
CANVA_BRAND_TEMPLATE_ID=your_brand_template_id_here
